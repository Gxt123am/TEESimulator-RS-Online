<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config for OmegaRelay Provider.

  For maximum compatibility, cleartext (ws://) is allowed to ALL hosts.
  This lets users connect to any relay server IP without rebuilding the APK.

  Security note: The relay protocol itself authenticates via PSK, so even
  over cleartext the connection cannot be used without the shared secret.
  For production deployments, wss:// with a real TLS cert is still recommended.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </base-config>
</network-security-config>
